# Copy to `.env.dusk.local` (gitignored). Laravel loads it when you run `php artisan dusk`
# (see `vendor/laravel/dusk/src/Console/DuskCommand.php` — `.env.dusk.{APP_ENV}` or `.env.dusk`).
#
# Keep APP_URL and DB_* in sync with `phpunit.dusk.xml` and the server you run for the browser.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/dusk.sqlite

BROADCAST_CONNECTION=null
CACHE_STORE=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=array

PAYSTACK_SECRET_KEY=sk_test_dusk
