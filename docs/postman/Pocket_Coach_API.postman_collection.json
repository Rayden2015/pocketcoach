				{
					"name": "Reflection — latest",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/tenants/{{tenant_slug}}/reflection-prompts/latest"
					}
				},
				{
					"name": "Reflection — show",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/tenants/{{tenant_slug}}/reflection-prompts/{{reflection_prompt_id}}"
