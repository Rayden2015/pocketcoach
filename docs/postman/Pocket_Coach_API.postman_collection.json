{
	"info": {
		"_postman_id": "a1b2c3d4-pocket-coach-api",
		"name": "Pocket Coach API",
		"description": "Laravel Sanctum API for Pocket Coach LMS.\n\n**Setup:** Import this file in Postman. Set collection variables: `base_url` (e.g. `http://127.0.0.1:8000/api`), `tenant_slug` (tenant **slug**, not numeric id).\n\n**Auth:** Run **Register** or **Login**; a test script saves `token` to collection variables. Other requests use `Authorization: Bearer {{token}}`.\n\n**Catalog:** The list may include a synthetic **Single courses** program (`id` 0, `slug` `_standalone`) when the tenant has published courses without a program (`program_id` null).\n\n**Reflections:** Endpoints return **404** when reflections are disabled for the tenant. **Latest** returns 200 with `{\"data\": null}` when there is no published prompt.\n\n**Note:** `{{tenant_slug}}` must match a row in `tenants.slug`. Admin routes require a user with staff role (`owner`, `admin`, or `instructor`) on that tenant.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://127.0.0.1:8000/api" },
		{ "key": "tenant_slug", "value": "adeola" },
		{ "key": "token", "value": "" },
		{ "key": "program_id", "value": "1" },
		{ "key": "course_id", "value": "1" },
		{ "key": "module_id", "value": "1" },
		{ "key": "lesson_id", "value": "1" },
		{ "key": "product_id", "value": "1" },
		{ "key": "reflection_prompt_id", "value": "1" },
		{ "key": "notification_id", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Auth (public)",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"try {",
									"    var j = pm.response.json();",
									"    if (j.token) { pm.collectionVariables.set('token', j.token); }",
									"} catch (e) { }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Demo Learner\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
						},
						"url": "{{base_url}}/v1/register"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"try {",
									"    var j = pm.response.json();",
									"    if (j.token) { pm.collectionVariables.set('token', j.token); }",
									"} catch (e) { }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"learner@pocketcoach.test\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{base_url}}/v1/login"
					}
				},
				{
					"name": "Google (id_token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"try {",
									"    var j = pm.response.json();",
									"    if (j.token) { pm.collectionVariables.set('token', j.token); }",
									"} catch (e) { }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_token\": \"<paste JWT from Google Sign-In (mobile) or OAuth Playground>\"\n}"
						},
						"url": "{{base_url}}/v1/auth/google",
						"description": "Backend verifies the token with Google using `GOOGLE_CLIENT_ID` (Web client ID). Same client ID must be used as `serverClientId` in Flutter `google_sign_in`."
					}
				}
			]
		},
		{
			"name": "Auth (Sanctum)",
			"item": [
				{
