						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/tenants/{{tenant_slug}}/reflection-prompts/{{reflection_prompt_id}}/view"
					}
				},
				{
					"name": "Reflection — save response",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"body\": \"My reflection text from Postman.\"\n}"
						},
						"url": "{{base_url}}/v1/tenants/{{tenant_slug}}/reflection-prompts/{{reflection_prompt_id}}/response"
					}
				}
			]
		},
