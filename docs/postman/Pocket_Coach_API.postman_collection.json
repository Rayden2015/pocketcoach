				{
					"name": "Notifications — mark read",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/notifications/{{notification_id}}",
						"description": "Set `notification_id` from the list response (`id` is a UUID string)."
					}
				},
				{
					"name": "Notifications — mark all read",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/v1/notifications/read-all"
					}
